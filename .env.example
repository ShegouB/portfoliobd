# ============================================================
#  PORTFOLIO BORIS DJAGOU — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# --- NOTION ---
# Clé secrète de ton intégration Notion
# Obtenir sur : https://www.notion.so/my-integrations
NOTION_API_KEY=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID de ta base de données Notion (Projets)
# Obtenir depuis l'URL de la base : notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_PROJECTS_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID de ta base de données Notion (Blog / Journal de bord) — optionnel
NOTION_BLOG_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- EMAILJS ---
# Créer un compte sur https://www.emailjs.com
# Service ID (ex: service_xxxxxxx) dans Email Services
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx

# Template ID (ex: template_xxxxxxx) dans Email Templates
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Public Key (dans Account > API Keys)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=XXXXXXXXXXXXXXXXXXXXXXX

# --- NEXT.JS ---
NEXT_PUBLIC_SITE_URL=https://borisdjagou.dev
